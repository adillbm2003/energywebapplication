{
  "name": "bermuds",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:gh-pages": "vite build --mode gh-pages && node scripts/copy-spa-fallback.mjs",
    "build:portal": "cd portal && npm install --legacy-peer-deps && npm run build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "node server.cjs",
    "migrate": "node migrate.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1067.0",
    "@aws-sdk/s3-request-presigner": "^3.1067.0",
    "@tailwindcss/vite": "^4.3.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "framer-motion": "^12.40.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "leaflet": "^1.9.4",
    "multer": "^2.1.1",
    "pg": "^8.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.17.0",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.3.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
