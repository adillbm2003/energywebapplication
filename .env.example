# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8000

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_postgres_password
PGDATABASE=cms_energy_bm

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Change this to a long random string in production
JWT_SECRET=change_me_in_production

# ─── CORS ─────────────────────────────────────────────────────────────────────
# In production set this to your CloudFront domain(s), comma-separated,
# e.g. https://xxxx.cloudfront.net,https://energybm-frontend.s3-website.us-east-2.amazonaws.com
APPROVED_ORIGINS=http://localhost:8000,http://localhost:5173,http://localhost:5174

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# Leave EMPTY for local dev — the Vite dev server proxies /api and /uploads to PORT automatically.
# For production builds set to the deployed backend URL (the Elastic Beanstalk env URL
# or the CloudFront domain that fronts it).
VITE_API_URL=

# ─── File Storage (AWS S3 — required in production; defaults to local ./uploads locally) ─────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-2
# AWS_S3_BUCKET=energybm-uploads

# ─── Production (AWS Elastic Beanstalk) ───────────────────────────────────────
# Set these as EB environment properties (eb setenv ...), NOT in this file:
#   NODE_ENV=production  PORT=8080  DATABASE_URL=postgres://...(RDS)
#   JWT_SECRET=<32-char random>   ← REQUIRED: the server refuses to boot in
#   production without a strong, non-default JWT_SECRET.
