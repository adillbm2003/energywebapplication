# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8000

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_postgres_password
PGDATABASE=cms_energy_bm

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Change this to a long random string in production
JWT_SECRET=change_me_in_production

# ─── CORS ─────────────────────────────────────────────────────────────────────
APPROVED_ORIGINS=http://localhost:8000,http://localhost:5173,http://localhost:5174

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# Leave EMPTY for local dev — the Vite dev server proxies /api and /uploads to PORT automatically.
# Set to your deployed backend URL for production builds e.g. https://your-backend.railway.app
VITE_API_URL=

# ─── File Storage (optional — defaults to local ./uploads folder) ─────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket-name

# ─── Production (set automatically by Railway — do not add manually) ──────────
# RAILWAY_PUBLIC_DOMAIN=your-app.railway.app
