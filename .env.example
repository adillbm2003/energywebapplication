# Application Configuration
NODE_ENV=development # Options: development, staging, production
PORT=8000

# PostgreSQL Configuration
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_secure_password_here
PGDATABASE=cms_energy_bm

# Connection URL override (useful for Heroku/Supabase/AWS RDS deployments)
# DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# Authentication
JWT_SECRET=your_jwt_secret_token_here
APPROVED_ORIGINS=http://localhost:8000,http://localhost:5173

# AWS S3 Cloud Storage
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your_aws_s3_bucket_name
